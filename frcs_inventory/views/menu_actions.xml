<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Put it under Inventory / Reporting; adjust parent if needed -->
    <menuitem id="menu_frcs_inventory_root" name="FRCS Inventory"
              parent="stock.menu_stock_root" sequence="95"/>


    <record id="action_url_product_master_xlsx" model="ir.actions.act_url">
      <field name="name">Download FRCS Product Master (XLSX)</field>
      <field name="type">ir.actions.act_url</field>
      <field name="url">/frcs_inventory/product_master_xlsx</field>
      <field name="target">self</field>
    </record>

    <menuitem id="menu_frcs_product_master_xlsx" name="Product Master (XLSX)"
              parent="menu_frcs_inventory_root" action="action_url_product_master_xlsx"
              sequence="1"/>

    <!-- Products by Category: grouped list view shortcut under Inventory > Products -->
    <record id="action_product_grouped_by_category" model="ir.actions.act_window">
      <field name="name">Products by Category</field>
      <field name="res_model">product.template</field>
      <field name="view_mode">list,form</field>
      <field name="view_id" ref="frcs_inventory.view_product_tree_grouped_category"/>
      <field name="context">{'group_by': 'categ_id'}</field>
    </record>

    <menuitem id="menu_product_grouped_category" name="Products by Category"
              parent="stock.menu_stock_inventory_control"
              action="action_product_grouped_by_category" sequence="50"/>

    <!-- Tax Products menus are defined in tax_products_views.xml -->

    <!-- Wizard action & bindings -->
    <record id="action_tax_bulk_wizard" model="ir.actions.act_window">
      <field name="name">Apply or Remove Tax</field>
      <field name="res_model">tax.bulk.wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
    </record>

    <record id="action_tax_bulk_wizard_bind_product_template" model="ir.actions.act_window">
      <field name="name">Bulk Tax Update</field>
      <field name="res_model">tax.bulk.wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
      <field name="binding_model_id" ref="product.model_product_template"/>
      <field name="binding_type">action</field>
    </record>

    <record id="action_tax_bulk_wizard_bind_tax_products" model="ir.actions.act_window">
      <field name="name">Bulk Tax Update</field>
      <field name="res_model">tax.bulk.wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
      <field name="binding_model_id" ref="frcs_inventory.model_tax_products"/>
      <field name="binding_type">action</field>
    </record>
</odoo>
