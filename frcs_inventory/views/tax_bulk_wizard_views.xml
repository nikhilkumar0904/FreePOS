<odoo>
    <record id="view_tax_bulk_wizard_form" model="ir.ui.view">
      <field name="name">tax.bulk.wizard.form</field>
      <field name="model">tax.bulk.wizard</field>
      <field name="arch" type="xml">
        <form string="Bulk Tax Action">
          <group>
            <field name="tax_id"
                   domain="[('type_tax_use','=','sale'),
                             ('active','=', True),
                             ('tax_group_id.name','=','FRCS VAT'),
                             '|', ('company_id','=', False), ('company_id','in', allowed_company_ids)]"/>
            <field name="action_type"/>
          </group>
          <footer>
            <button name="action_confirm" type="object" string="Confirm" class="btn-primary"/>
            <button string="Cancel" class="btn-secondary" special="cancel"/>
          </footer>
        </form>
      </field>
    </record>

    <!-- Open wizard action -->
    <record id="action_tax_bulk_wizard" model="ir.actions.act_window">
      <field name="name">Apply or Remove Tax</field>
      <field name="res_model">tax.bulk.wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
    </record>

    <!-- Bind the wizard to product.template Actions menu -->
    <record id="action_tax_bulk_wizard_bind_product_template" model="ir.actions.act_window">
      <field name="name">Bulk Tax Update</field>
      <field name="res_model">tax.bulk.wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
      <field name="binding_model_id" ref="product.model_product_template"/>
      <field name="binding_type">action</field>
    </record>

    <!-- Bind the wizard to tax.products Actions menu as well -->
    <record id="action_tax_bulk_wizard_bind_tax_products" model="ir.actions.act_window">
      <field name="name">Bulk Tax Update</field>
      <field name="res_model">tax.bulk.wizard</field>
      <field name="view_mode">form</field>
      <field name="target">new</field>
      <field name="binding_model_id" ref="model_tax_products"/>
      <field name="binding_type">action</field>
    </record>
</odoo>
