<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="frcs_inventory.InventoryDashboard">
        <div class="o_frcs_inventory_dashboard p-4">
            <h2>📊 Inventory Insights</h2>
            <div class="row mt-3">
                <div class="col-6">
                    <h3>🔥 Fast-Moving Products</h3>
                    <table class="table table-striped">
                        <thead>
                            <tr><th>Product</th><th>Sold Qty</th></tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.top_products" t-as="p" t-key="p.name">
                                <tr>
                                    <td><t t-esc="p.name"/></td>
                                    <td><t t-esc="p.qty_sold"/></td>
                                </tr>
                            </t>
                            <t t-if="!state.top_products.length">
                                <tr>
                                    <td colspan="2">No sales data available.</td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>

                <div class="col-6">
                    <h3>⏰ Products Near Expiry</h3>
                    <table class="table table-striped">
                        <thead>
                            <tr><th>Product</th><th>Expiry Date</th></tr>
                        </thead>
                        <tbody>
                            <t t-foreach="state.expiring_products" t-as="e" t-key="e.name">
                                <tr>
                                    <td><t t-esc="e.name"/></td>
                                    <td><t t-esc="e.product_expiry"/></td>
                                </tr>
                            </t>
                            <t t-if="!state.expiring_products.length">
                                <tr>
                                    <td colspan="2">No products expiring soon.</td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </t>
    
    <!-- Minimal template used by the redirect component -->
    <t t-name="frcs_inventory.RedirectStockDashboard">
        <div/>
    </t>
    
</templates>
