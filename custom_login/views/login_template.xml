<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="custom_login_layout" inherit_id="web.login_layout" name= "Login Layout">
        <xpath expr="t" position="replace">
            <t t-call="web.frontend_layout">
                <t t-set="html_data" t-value="{'style': 'height:100%;'}"/>
                <t t-set="body_classname" t-value="'bg-100'+('background-image' if login_page_custom_background else '')"/>
                <t t-set="no_header" t-value="True"/>
                <t t-set="no_footer" t-value="True"/>
                <t t-set="login_page_custom_background" t-value="env['ir.config_parameter'].sudo().get_param(
                'custom_login.custom_background') == 'True'"/>
                <t t-set="login_page_show_logo" t-value="env['ir.config_parameter'].sudo().get_param(
                'custom_login.show_logo') == 'True'"/>
                <t t-set="login_page_show_motto" t-value="env['ir.config_parameter'].sudo().get_param(
                'custom_login.show_motto')"/>
                <t t-set="login_page_motto_text" t-value="env['ir.config_parameter'].sudo().get_param(
                'custom_login.motto_text')"/>
                
                
                <section t-attf-class="h-100 d-flex align-items-center#{ 'bg-primary' if not login_page_custom_background else '' }"
                    t-att-style="'background-image: url(/web/binary/login_page_background_image); 
                    background-size: cover; background-position: center;'if login_page_custom_background else ''">
                    <div class="container">
                        <div class="row justify-content-center align-items-center" style="min-height:100vh">
                            <div class="col-12 col-md-6 col-xl-8">
                                <div class="d-flex justify-content-center">
                                    <div class="col-12">
                                        <div class="col-6" t-if="login_page_show_logo">
                                            <img src="/web/binary/login_logo" class="mx-auto d-block login-logo" style="max-height:256px;
                                            max-width:100%; width:auto"/>
                                        </div>
                                        <figure class="login-quote" t-if="login_page_show_motto">
                                            <blockquote class="blockquote">
                                                <p class="d-flex">
                                                    <i class="fa fa-quote-left fa-lg align-self-start text-warning me-2"></i>
                                                    <span class="my-2">
                                                        <t t-out="login_page_motto_text"/>
                                                    </span>
                                                    <i class="fa fa-quote-right fa-lg ms-2 align-self-end text-warning
                                                    me-2"></i>
                                                </p>
                                            </blockquote>
                                        </figure>
                                    </div>
                                </div>
                            </div>
                            <div class="col-12 col-md-6 col-xl-4">
                                <div class="card border-0 rounded-4">
                                    <div class="card-body p-3 p-md-4 p-xl-5">
                                        <h2 t-if="login_title_text" class="border-bottom mb-3 pb-2">
                                            <t t-out="login_title_text"/>
                                        </h2>
                                        <div class="o_login_form">
                                            <t t-out="0"/>
                                        </div>
                                        <div class="text-center small mt-4 pt-3 border-top" t-if="not disable_footer">
                                            <t t-if="not disable_database_manager">
                                                <a href="/web/database/manager"> Manage Databases</a>
                                            </t>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </t>
        </xpath>
    </template>
</odoo>
