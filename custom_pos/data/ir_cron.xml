<?xml version="1.0" encoding="UTF-8"?> 
<odoo> 
    <data noupdate="1">
        <record id="ir_cron_pos_print_job_process" model="ir.cron"> 
            <field name="name">POS: Process Print Jobs</field> 
            <field name="model_id" ref="model_pos_print_job"/> 
            <field name="state">code</field> <field name="code">model.cron_process_jobs()</field> 
            <field name="interval_type">minutes</field> <field name="interval_number">1</field> 
            <field name="nextcall" eval="(DateTime.now() + relativedelta(minutes=1)).strftime('%Y-%m-%d %H:%M:%S')"/> 
            <field name="active" eval="True"/> 
            <field name="user_id" ref="base.user_admin"/>
        </record> 
    </data>
</odoo>