<?xml version="1.0" encoding="utf-8"?>
<odoo> 
    <record id="view_pos_config_form_inherit_raw_printer_ip" model="ir.ui.view">
        <field name="name">pos.config.form.raw.printer.ip</field>
        <field name="model">pos.config</field>
        <field name="inherit_id" ref="point_of_sale.pos_config_view_form"/> 
        <field name="arch" type="xml"> 
            <xpath expr="//setting[@id='other_devices']" position="after"> 
                <setting string="ESC/POS Printer (Raw)" help="IP of the raw ESC/POS printer (TCP 9100)."> 
                    <field name="raw_printer_ip" placeholder="192.168.x.x"/> 
                </setting> 
            </xpath> 
        </field>

    </record>
</odoo>