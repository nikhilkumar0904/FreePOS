<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
  <t t-inherit="point_of_sale.ActionpadWidget" t-inherit-mode="extension" owl="1">
    <xpath expr="//div[contains(@class,'validation')]" position="inside">
      <button t-if="props.secondaryActionToTrigger"
              class="btn btn-outline-primary btn-lg py-3 flex-fill frcs-reprint"
              t-on-click="props.secondaryActionToTrigger"
              t-esc="props.secondaryActionName or 'Secondary'"/>
    </xpath>
  </t>
</templates>
