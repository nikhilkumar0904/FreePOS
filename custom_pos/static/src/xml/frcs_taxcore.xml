<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">

    <t t-inherit="point_of_sale.PaymentScreenValidate" t-inherit-mode="extension" owl="1">
        <xpath expr="//button[contains(@class, 'validation-button')]" position="replace">
            <button class="button next validation btn btn-success btn-lg w-75 py-3 lh-lg my-custom-class"
                t-attf-class="{{ currentOrder.is_paid() and currentOrder._isValidEmptyOrder() ? 'highlight' : 'disabled'}}"
                t-on-click="() => this.validateOrder()">
                <span class="next_text">
                    <t t-if="pos.proformaMode">
                        PROFORMA SALE
                    </t>
                    <t t-elif="pos.trainingMode">
                        TRAINING SALE
                    </t>
                    <t t-else="">
                        CONFIRM SALE
                    </t>
                   
                </span>
            </button>
        </xpath>
    
    </t>
    <t t-inherit="point_of_sale.Chrome" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[contains(@class, 'pos-content')]" position="before">
            <textarea id="invoiceInput" class="d-none"></textarea>
            <textarea id="invoiceOutput" class="d-none"></textarea>
            <button id="taxcore_sign_element"
                    class="d-none"
                    data-taxcore-vsdc-url="https://vsdc.sandbox.vms.frcs.org.fj/"
                    data-taxcore-input-id="invoiceInput"
                    data-taxcore-output-id="invoiceOutput"
                    data-taxcore-debug="true"></button>

            <div id="taxcore-loading" class="d-none overlay-spinner d-flex flex-column align-items-center">
                <div class="spinner-border text-light spinner" role="status"></div>
                <span class="mt-3 spinner-text">Signing invoice...</span>
            </div>
        </xpath>
    </t>
    
    <!--Removing the invoicing buttons at checkout-->
    <t t-inherit="point_of_sale.PaymentScreen" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[contains(@class, 'left-content')]" position="replace">
            <div class="left-content d-flex flex-column col-md-4 p-2">
                <t t-call="point_of_sale.PaymentScreenMethods" />
                <Numpad class="'py-2'"  buttons="getNumpadButtons()"/>
                <div t-attf-class="d-flex flex-row gap-2">
                    <t t-call="point_of_sale.PaymentScreenBack" />
                    <t t-call="point_of_sale.PaymentScreenValidate" />
                </div>
            </div>
        </xpath>
    </t>

    <!--Formatting response from Taxcore for customer receipt-->
    <t t-inherit="point_of_sale.OrderReceipt" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[contains(@class, 'pos-receipt')]" position="replace">
            <t t-set="taxcore" t-value="props.data and props.data.taxcore_response"/>
            <t t-if="taxcore">
                <div class="taxcore-receipt-block mt-3">         
                    <t t-if="taxcore.journal_before_end">
                        <t t-foreach="taxcore.journal_before_end" t-as="line" t-key="line.idx">
                            <pre class="journal-text"><t t-esc="line.text"/></pre>
                        </t>
                    </t>

                    <t t-if="taxcore.verificationQRCode">
                        <img class="pos-receipt-qrcode mt-3"
                            t-att-src="'data:image/png;base64,' + taxcore.verificationQRCode"/>
                    </t>

                    <t t-if="taxcore.journal_end_line">
                        <pre><t t-esc="'\n' + taxcore.journal_end_line"/></pre>
                    </t>

                </div>
            </t>
        </xpath>
    </t>
    



</templates>
