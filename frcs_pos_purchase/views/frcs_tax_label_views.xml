<odoo>
  <!-- List view -->
  <record id="view_frcs_tax_label_tree" model="ir.ui.view">
    <field name="name">frcs.purchase.tax.label.list</field>
    <field name="model">frcs.purchase.tax.label</field>
    <field name="type">list</field>
    <field name="arch" type="xml">
      <list string="VAT Labels (FRCS)">
        <field name="code"/>
        <field name="name"/>
        <field name="rate"/>
        <field name="active"/>
      </list>
    </field>
  </record>

  <!-- Form view -->
  <record id="view_frcs_tax_label_form" model="ir.ui.view">
    <field name="name">frcs.purchase.tax.label.form</field>
    <field name="model">frcs.purchase.tax.label</field>
    <field name="arch" type="xml">
      <form string="VAT Label (FRCS)">
        <sheet>
          <group>
            <field name="code"/>
            <field name="name"/>
            <field name="rate"/>
            <field name="active"/>
          </group>
        </sheet>
      </form>
    </field>
  </record>

  <!-- Action with explicit view assignment -->
  <record id="action_frcs_tax_label" model="ir.actions.act_window">
    <field name="name">FRCS VAT Labels</field>
    <field name="res_model">frcs.purchase.tax.label</field>
    <field name="view_mode">list,form</field>
    <field name="target">current</field>
  </record>

  <record id="action_frcs_tax_label_view_list" model="ir.actions.act_window.view">
    <field name="sequence" eval="1"/>
    <field name="view_mode">list</field>
    <field name="view_id" ref="view_frcs_tax_label_tree"/>
    <field name="act_window_id" ref="action_frcs_tax_label"/>
  </record>

  <record id="action_frcs_tax_label_view_form" model="ir.actions.act_window.view">
    <field name="sequence" eval="2"/>
    <field name="view_mode">form</field>
    <field name="view_id" ref="view_frcs_tax_label_form"/>
    <field name="act_window_id" ref="action_frcs_tax_label"/>
  </record>

  <!-- Menus under Purchase Configuration -->
  <menuitem id="menu_frcs_config_root"
            name="FRCS"
            parent="purchase.menu_purchase_config"
            sequence="95"/>

  <menuitem id="menu_frcs_tax_labels"
            name="VAT Labels (FRCS)"
            parent="menu_frcs_config_root"
            action="action_frcs_tax_label"
            sequence="10"/>
</odoo>
