<odoo>
    <data>
        <record id="view_partner_form_frcs_purchase" model="ir.ui.view">
            <field name="name">res.partner.form.frcs.purchase</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="base.view_partner_form"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='sales_purchases']/group[last()]" position="after">
                    <group string="FRCS">
                        <field name="frcs_tin"/>
                        <field name="frcs_is_vat_registered"/>
                        <field name="frcs_cost_center"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
