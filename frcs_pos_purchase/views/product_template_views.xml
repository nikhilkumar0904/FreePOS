<odoo>
    <data>
        <record id="view_product_template_form_frcs_purchase" model="ir.ui.view">
            <field name="name">product.template.form.frcs.purchase</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='purchase']/group" position="inside">
                    <group string="FRCS">
                        <field name="frcs_default_vat_label"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
