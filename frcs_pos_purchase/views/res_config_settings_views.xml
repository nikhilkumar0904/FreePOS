<odoo>
    <data>
        <record id="res_config_settings_view_form_frcs_purchase" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.frcs.purchase</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="purchase.res_config_settings_view_form_purchase"/>
            <field name="arch" type="xml">
                <xpath expr="//app[@name='purchase']/block[@name='purchase_setting_container']" position="after">
                    <block title="FRCS Purchase" name="frcs_purchase_settings">
                        <setting id="frcs_require_vendor_tin_setting"
                                 help="Enforce that vendors have an FRCS TIN before confirming purchase orders.">
                            <field name="frcs_require_vendor_tin"/>
                        </setting>
                    </block>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
